{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "wispdb": ["../../packages/core/src/index.ts"],
      "wispdb/*": ["../../packages/core/src/*"],
      "@wispdb/gpu": ["../../packages/gpu/src/index.ts"],
      "@wispdb/gpu/*": ["../../packages/gpu/src/*"],
      "@wispdb/utils": ["../../packages/utils/src/index.ts"],
      "@wispdb/utils/*": ["../../packages/utils/src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src", "../../packages/gpu/src/types.d.ts"]
}
